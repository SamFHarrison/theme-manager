{
  "name": "@bigsams/theme-manager",
  "version": "0.1.0",
  "description": "A package for changing and persisting light, auto and dark themes in React apps.",
  "author": {
    "name": "Sam F-Harrison",
    "url": "https://github.com/SamFHarrison"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "keywords": [
    "react",
    "theme",
    "dark-mode",
    "light-mode",
    "hook",
    "theming"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SamFHarrison/theme-manager"
  },
  "homepage": "https://github.com/SamFHarrison/theme-manager#readme",
  "bugs": {
    "url": "https://github.com/SamFHarrison/theme-manager/issues"
  }
}
